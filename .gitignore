# This repo's OWN working memory is private. A public repo means a public
# .context/, so we do NOT ship a development journal/state.
/.context/

# Secrets — NEVER commit.
.env
.env.*

# Per-project harness install dirs — regenerated by `celeborn grok sync-rules` / the adapter
# installer every session (managed blocks). The committed SOURCE adapter lives in grok/.
.grok/
.codex/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
